[project]
requires = ["nodejs-24"]
entrypoint = "src/app.ts"

[dev]
build = ["pnpm", "install", "--ignore-scripts"]
run = ["bash", "-c", "cd /workspace/projects && export NODE_ENV=prod && node data/serve/app.js"]

[deploy]
build = ["bash", "-c", "export npm_config_disturl=https://registry.npmmirror.com/mirrors/node && export npm_config_build_from_source=false && cd /workspace/projects && pnpm install --ignore-scripts"]
run = ["bash", "-c", "cd /workspace/projects && export NODE_ENV=prod && export NEON_CONNECTION_STRING='postgresql://neondb_owner:npg_3IYwH7NSfkAs@ep-wispy-water-a19sv7bc-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require' && node data/serve/app.js"]
