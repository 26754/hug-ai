[project]
requires = ["nodejs-24"]
entrypoint = "src/app.ts"

[dev]
build = ["pnpm", "install"]
run = ["bash", "-c", "cd /workspace/projects && pnpm start"]

[deploy]
build = [
  "bash", "/workspace/projects/scripts/deploy.sh"
]
run = ["bash", "-c", "cd /workspace/projects && node data/serve/app.js"]
