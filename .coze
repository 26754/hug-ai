[project]
requires = ["nodejs-24"]
entrypoint = "src/app.ts"

[dev]
build = ["pnpm", "install"]
run = ["node", "data/serve/app.js"]

[deploy]
build = [
  "bash",
  "-c",
  "cd ${COZE_WORKSPACE_PATH} && pnpm install && cd ${COZE_WORKSPACE_PATH}/node_modules/.pnpm/better-sqlite3@12.9.0/node_modules/better-sqlite3 && npx -y node-gyp@10.1.0 rebuild --release && cd ${COZE_WORKSPACE_PATH}/src-web && pnpm install && pnpm build && cd ${COZE_WORKSPACE_PATH} && NODE_PATH=${COZE_WORKSPACE_PATH}/node_modules/.pnpm/node_modules node ${COZE_WORKSPACE_PATH}/node_modules/.pnpm/tsx@4.21.0/node_modules/tsx/dist/cli.cjs scripts/build.ts"
]
run = ["node", "data/serve/app.js"]
